# Скопируйте в .env.local и подставьте значения.
#
# Prisma CLI сам по себе читает только .env (не .env.local).
# В проекте команды npm подгружают сначала .env, потом .env.local (локальный перекрывает):
#   npm run db:migrate:deploy
#   npm run db:seed
# Руками: npx dotenv -o -e .env -e .env.local -- prisma migrate deploy
# Хост: localhost (БД на этой машине) или IP/домен сервера (если порт 5432 доступен снаружи).
DATABASE_URL="postgresql://smmplaner_app:YOUR_PASSWORD@localhost:5432/smmplaner"
#
# --- Локально через Docker (порт 5433, как у SSH-туннеля в примере ниже) ---
#   POSTGRES_PASSWORD=тот_же_что_в_DATABASE_URL docker compose up -d
#   DATABASE_URL="postgresql://smmplaner_app:YOUR_PASSWORD@localhost:5433/smmplaner"
#   npm run db:migrate:deploy && npm run db:seed
#
# --- Если `npm run db:migrate` (migrate dev) падает с P3014: permission denied to create database ---
# У пользователя БД нет права CREATEDB — Prisma не может создать «теневую» БД. Варианты:
# 1) Локальная разработка без истории миграций: `npm run db:push` — подтянет схему в текущую БД.
# 2) Оставить migrate dev: один раз создайте пустую БД (под суперпользователем postgres), например
#      CREATE DATABASE smmplaner_shadow OWNER smmplaner_app;
#    затем в prisma/schema.prisma в datasource добавьте строку:
#      shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
#    и здесь:
# SHADOW_DATABASE_URL="postgresql://smmplaner_app:YOUR_PASSWORD@localhost:5432/smmplaner_shadow"
#    (хост/порт/пользователь как у DATABASE_URL, другое имя базы.)
# На проде обычно `npm run db:migrate:deploy` — shadow database не используется.
#
# Сид: после первого импорта демо-клиентов/постов на проде задайте SEED_DEMO_DATA=0,
# чтобы повторный prisma db seed не удалял пользовательский контент.
# SEED_DEMO_DATA=0
#
# --- Вариант: SSH-туннель (БД на VPS слушает только 127.0.0.1:5432) ---
# На своём ПК в отдельном терминале держите сессию:
#   ssh -N -L 5433:127.0.0.1:5432 root@ВАШ_IP_ИЛИ_ДОМЕН
# (-N = не открывать shell, только туннель; локальный порт 5433 можно заменить.)
# В .env.local укажите хост и порт туннеля:
#   DATABASE_URL="postgresql://USER:PASS@127.0.0.1:5433/smmplaner"
# Потом: npm run db:migrate:deploy, npm run db:seed, npm run dev — пока ssh-сессия открыта.

# Секрет для подписи сессий NextAuth — любая длинная случайная строка, НЕ из интернета.
# Сгенерировать на своём ПК или на сервере:
# Вставьте вывод в кавычки ниже и то же значение продублируйте в .env на сервере / в PM2.
AUTH_SECRET="вставьте_сюда_результат_openssl_rand"

# Прод: публичный URL сайта (для callback и cookies)
# AUTH_URL="https://wyacheslav-web.online"

# Плановая публикация в Telegram: секрет для GET/POST /api/cron/publish-telegram
# (заголовок Authorization: Bearer <CRON_SECRET> или ?secret=<CRON_SECRET>).
# На Vercel задайте CRON_SECRET в переменных окружения — платформа подставит его в cron-запросы.
# CRON_SECRET="сгенерируйте_openssl_rand_-hex_32"
#
# Self-host / PM2: по умолчанию Next раз в минуту сам зовёт плановую публикацию TG (см. src/instrumentation.ts).
# Выключает встроенный опрос, если публикуете только crontab’ом: TELEGRAM_SCHEDULE_POLL=0
# PM2 в нескольких воркерах может задвоить публикации — лучше -i 1 или TELEGRAM_SCHEDULE_POLL=0 + один curl в cron.

# Публичный URL (если AUTH_URL не подходит): для картинок по https и прочих путей вне /uploads/posts/…
# Файлы из public/uploads/posts/… сервер отдаёт в Telegram с диска и без этого URL.
# APP_BASE_URL="https://wyacheslav-web.online"
#
# --- VK ID: кнопка «Войти через VK» в форме клиента (платформа ВКонтакте) ---
# ID приложения из vk.com/apps?act=manage и тот же базовый redirect URL, что в настройках VK
# (доверенные redirect URI). Для локалки добавьте http://localhost:3000 в приложение VK.
# NEXT_PUBLIC_VK_APP_ID="54563587"
# NEXT_PUBLIC_VK_REDIRECT_URL="https://ваш-домен.example"
# Необязательно: scope для авторизации VK ID. В документации VK ID список задаётся через пробелы;
# запятые в значении тоже можно — приложение приведёт их к пробелам. По умолчанию:
# vkid.personal_info wall photos groups offline
# В «Доступах» VK ID часто видны только профиль / почта / телефон — не ищите там отдельные wall/photos.
# Если после входа через кнопку api.vk.com отвечает 15 или 1051 — ключ группы, токен с dev.vk.com
# вручную или согласование с поддержкой VK ID (см. документацию create-application / devsupport).
# После смены настроек заново войдите через кнопку VK ID на сайте.
# NEXT_PUBLIC_VK_SCOPE="vkid.personal_info wall photos groups offline"
