# Скопируйте в .env.local и подставьте значения.
#
# Prisma CLI сам по себе читает только .env (не .env.local).
# В проекте команды npm подгружают сначала .env, потом .env.local (локальный перекрывает):
#   npm run db:migrate:deploy
#   npm run db:seed
# Руками: npx dotenv -o -e .env -e .env.local -- prisma migrate deploy
# Хост: localhost (БД на этой машине) или IP/домен сервера (если порт 5432 доступен снаружи).
DATABASE_URL="postgresql://smmplaner_app:YOUR_PASSWORD@localhost:5432/smmplaner"
#
# --- Вариант: SSH-туннель (БД на VPS слушает только 127.0.0.1:5432) ---
# На своём ПК в отдельном терминале держите сессию:
#   ssh -N -L 5433:127.0.0.1:5432 root@ВАШ_IP_ИЛИ_ДОМЕН
# (-N = не открывать shell, только туннель; локальный порт 5433 можно заменить.)
# В .env.local укажите хост и порт туннеля:
#   DATABASE_URL="postgresql://USER:PASS@127.0.0.1:5433/smmplaner"
# Потом: npm run db:migrate:deploy, npm run db:seed, npm run dev — пока ssh-сессия открыта.

# Секрет для подписи сессий NextAuth — любая длинная случайная строка, НЕ из интернета.
# Сгенерировать на своём ПК или на сервере:
# Вставьте вывод в кавычки ниже и то же значение продублируйте в .env на сервере / в PM2.
AUTH_SECRET="вставьте_сюда_результат_openssl_rand"

# Прод: публичный URL сайта (для callback и cookies)
# AUTH_URL="https://wyacheslav-web.online"
