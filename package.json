{
  "name": "smmplaner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:check": "node scripts/check-db.mjs",
    "db:generate": "dotenv -o -e .env -e .env.local -- prisma generate",
    "db:migrate": "dotenv -o -e .env -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -o -e .env -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -o -e .env -e .env.local -- prisma db push",
    "db:seed": "dotenv -o -e .env -e .env.local -- prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pg": "^8.20.0",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
