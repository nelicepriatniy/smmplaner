generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostDraftStatus {
  draft
  in_review
  scheduled
  published
  rejected
}

enum PostContentType {
  feed
  photo
  reels
  stories
}

enum ReviewCommentSide {
  self
  client
}

enum ActivityKind {
  client_comment
  client_approval
  client_rejection
  post_published
  client_added
  post_scheduled
}

enum ClientPlatform {
  instagram
  telegram
  vk
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  clients      Client[]
  posts        Post[]
  activities   Activity[]

  @@map("users")
}

model Client {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  fullName        String   @map("full_name")
  /// JSON array of 1–2 sphere labels
  activitySpheres Json     @map("activity_spheres")
  contact         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts   ClientSocialAccount[]

  @@index([userId])
  @@map("clients")
}

/// Подключённая соцсеть клиента (Instagram / Telegram / ВК): учётные данные и посты.
model ClientSocialAccount {
  id                      String         @id @default(cuid())
  clientId                String         @map("client_id")
  platform                ClientPlatform
  instagramUsername       String         @default("") @map("instagram_username")
  instagramBusinessId     String?        @map("instagram_business_id")
  facebookPageId          String?        @map("facebook_page_id")
  /// Чувствительные данные: храните БД в доверенной среде; для продакшена рассмотрите шифрование/vault.
  pageAccessToken         String?        @map("page_access_token") @db.Text
  businessAccountConfirmed Boolean       @default(false) @map("business_account_confirmed")
  /// Токен бота от @BotFather (секрет); для отправки в Telegram Bot API.
  telegramBotToken        String?        @map("telegram_bot_token") @db.Text
  /// ID чата/канала, куда отправлять посты.
  telegramChatId          String?        @map("telegram_chat_id") @db.Text
  /// Токен пользователя или сообщества ВК для вызова API (секрет).
  vkAccessToken           String?        @map("vk_access_token") @db.Text
  /// owner_id для wall.post: отрицательный — стена сообщества, положительный — пользователя.
  vkOwnerId               String?        @map("vk_owner_id") @db.Text
  /// Публиковать от имени сообщества (параметр from_group в wall.post).
  vkFromGroup             Boolean        @default(false) @map("vk_from_group")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  posts  Post[]

  @@index([clientId])
  @@map("client_social_accounts")
}

model Post {
  id                      String           @id @default(cuid())
  userId                  String           @map("user_id")
  clientSocialAccountId   String           @map("client_social_account_id")
  status                  PostDraftStatus
  postType                PostContentType  @map("post_type")
  caption                 String           @db.Text
  location                String           @default("")
  firstComment            String           @default("") @map("first_comment")
  altText                 String           @default("") @map("alt_text")
  imageUrls               Json             @map("image_urls")
  publishDate             String           @map("publish_date")
  publishTime             String           @map("publish_time")
  createdAt               DateTime         @map("created_at")
  clientReviewToken       String           @unique @map("client_review_token")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount ClientSocialAccount  @relation(fields: [clientSocialAccountId], references: [id], onDelete: Cascade)
  discussion    PostReviewComment[]

  @@index([userId])
  @@index([clientSocialAccountId])
  @@index([userId, publishDate])
  @@map("posts")
}

model PostReviewComment {
  id        String            @id @default(cuid())
  postId    String            @map("post_id")
  side      ReviewCommentSide
  text      String            @db.Text
  createdAt DateTime          @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_review_comments")
}

model Activity {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  kind      ActivityKind
  createdAt DateTime     @map("created_at")
  title     String
  detail    String?
  clientId  String?      @map("client_id")
  postId    String?      @map("post_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("activities")
}
